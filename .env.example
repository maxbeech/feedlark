# --- Database (Turso / libSQL) ---
# For local dev you can use a file: TURSO_DATABASE_URL=file:local.db
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- Auth ---
# 32+ char random string used to sign session JWTs. REQUIRED in production.
AUTH_SECRET=

# --- Public site URL (used for canonical links, RSS, widget origin, email links) ---
NEXT_PUBLIC_SITE_URL=https://www.feedlark.com

# --- Stripe (optional — billing degrades to 503 if unset) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
NEXT_PUBLIC_STRIPE_ENABLED=false
# Flip to true ONLY after activating Stripe Tax in the dashboard, else checkout errors.
STRIPE_TAX_ENABLED=false

# --- Email (Resend; optional — emails no-op if unset) ---
RESEND_API_KEY=
EMAIL_FROM=Feedlark <noreply@mail.feedlark.com>
# Svix signing secret for the Resend bounce/complaint webhook (/api/resend/webhook).
RESEND_WEBHOOK_SECRET=

# --- Rate limiting (Upstash Redis; optional — fails OPEN if unset) ---
# Auto-injected by the Upstash Vercel integration.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Error monitoring (Sentry; optional — no-ops if unset) ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- Cron (protects /api/cron/* ; Vercel injects this header automatically) ---
CRON_SECRET=

# --- AI duplicate-clustering (optional — feature hidden if unset) ---
# Any OpenAI-compatible endpoint; left blank = heuristic fallback only.
AI_API_KEY=
AI_API_BASE=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
